# ── Database ─────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<your-strong-password>

# ── RabbitMQ (local dev only, not needed when using Azure Service Bus) ──
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=<your-strong-password>

# ── JWT ──────────────────────────────────────────────────
# Minimum 32 characters, use a cryptographically random string
JWT_SECRET_KEY=<your-jwt-secret-minimum-32-characters>

# ── ASP.NET Core ─────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production

# ── Azure (leave empty for local development) ───────────
# Key Vault — set to pull secrets at startup
AZURE_KEYVAULT_VAULT_URI=

# Blob Storage — for employee documents
AZURE_BLOB_CONNECTION_STRING=

# Application Insights — for telemetry
AZURE_APPINSIGHTS_CONNECTION_STRING=

# Azure Service Bus — set to use instead of RabbitMQ
AZURE_SERVICEBUS_CONNECTION_STRING=
