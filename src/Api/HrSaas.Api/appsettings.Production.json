{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning",
        "Hangfire": "Warning",
        "MassTransit": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "Database": {
    "AutoMigrate": false
  },
  "Jwt": {
    "RequireHttpsMetadata": true
  },
  "Storage": {
    "Provider": "AzureBlob"
  },
  "FeatureManagement": {
    "BulkEmployeeImport": false,
    "AdvancedReporting": false,
    "LeaveApprovalWorkflow": true,
    "EmailNotifications": true,
    "SlackIntegration": false,
    "AuditLog": true,
    "CustomRoles": true,
    "MultiCurrencyBilling": false,
    "EmployeeSelfService": true,
    "ApiWebhooks": false
  },
  "AllowedHosts": "*"
}
